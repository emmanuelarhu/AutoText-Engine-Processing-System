<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="main.java.com.autotextengine.view.FileProcessingView"
      spacing="10">
    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="File:"/>
        <TextField fx:id="filePathField" HBox.hgrow="ALWAYS"/>
        <Button text="Browse" onAction="#handleBrowse"/>
        <Button text="Load" onAction="#handleLoadFile"/>
    </HBox>

    <Label text="Input Text:"/>
    <TextArea fx:id="inputTextArea" VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Operation:"/>
        <ComboBox fx:id="operationComboBox" promptText="Select operation..." HBox.hgrow="ALWAYS"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Clear Input" onAction="#handleClearInput"/>
        <Button text="Process" onAction="#handleProcessFile"/>
    </HBox>

    <Label text="Output Text:"/>
    <TextArea fx:id="outputTextArea" VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Clear Output" onAction="#handleClearOutput"/>
        <Button text="Save" onAction="#handleSaveFile"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" text="Ready"/>
    </HBox>
</VBox>